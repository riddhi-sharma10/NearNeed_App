<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back_arrow"
                    app:tint="@color/text_header"
                    android:contentDescription="@string/back_description" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="sans-serif-black"
                    android:text="Post Options"
                    android:textColor="@color/text_header"
                    android:textSize="18sp" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:fontFamily="sans-serif-black"
                android:text="What do you want to share?"
                android:textColor="@color/text_header"
                android:textSize="28sp"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="Select the type of post that best fits your needs."
                android:textColor="@color/text_muted"
                android:textSize="15sp" />

            <!-- GIG POST CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGigPost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/iconGigCard"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardBackgroundColor="#64748B"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/iconGig"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_toolbox_seeker"
                                app:tint="@color/white" />
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/badgeGig"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="#F1F5F9"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="PAID GIG"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/titleGig"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Post a Gig"
                        android:textColor="@color/black"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/descGig"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Offer a paid task to your local community. Perfect for skilled labor or quick help."
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:lineHeight="20sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContinueGig"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="Continue as Gig"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#64748B"
                        app:backgroundTint="#F1F5F9"
                        app:cornerRadius="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- COMMUNITY POST CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCommunityPost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/iconCommunityCard"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            app:cardBackgroundColor="#64748B"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/iconCommunity"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_nav_profile"
                                app:tint="@color/white" />
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/badgeCommunity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="#F1F5F9"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="COMMUNITY"
                            android:textColor="#64748B"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/titleCommunity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Community Need"
                        android:textColor="@color/black"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/descCommunity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Ask for volunteer help or share community updates. No payment required."
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:lineHeight="20sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContinueCommunity"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="Continue as Community"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#64748B"
                        app:backgroundTint="#F1F5F9"
                        app:cornerRadius="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_main_navbar_page" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
