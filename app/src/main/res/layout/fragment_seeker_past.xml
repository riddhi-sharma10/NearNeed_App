                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_profile_block_bookings"
                    android:padding="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile2"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="#DBEAFE"
                        android:src="@android:drawable/ic_menu_camera"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                        app:tint="#1E3A8A"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:id="@+id/llProfileInfo2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ASSIGNED PRO"
                            android:textColor="#9CA3AF"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Marcus Chen"
                                android:textColor="#1E3A8A"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/bg_rating_pill_white_bookings"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="6dp"
                                android:paddingVertical="2dp">

                                <ImageView
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:src="@android:drawable/star_on"
                                    app:tint="#D97706" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="3dp"
                                    android:text="4.7"
                                    android:textColor="#1E3A8A"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#FEF2F2"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvDesc2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="2dp"
                    android:text="Urgent leak detection and pipe replacement in the master bathroom. Cancellation due to..."
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFindAnother2"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Find Another"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:backgroundTint="#1E3A8A"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewDetails2"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Details"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        app:strokeColor="#DBEAFE" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 3: Deep Home Cleaning (Completed) -->
