<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center_horizontal"
    android:paddingHorizontal="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_floating_glass_navbar"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <FrameLayout
            android:id="@+id/nav_home_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <View
                android:id="@+id/nav_home_active_bg"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_light_blue"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/nav_home_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_home"
                app:tint="@color/text_muted" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/nav_map_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <View
                android:id="@+id/nav_map_active_bg"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_light_blue"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/nav_map_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_map_final"
                app:tint="@color/text_muted" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/nav_bookings_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <View
                android:id="@+id/nav_bookings_active_bg"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_light_blue"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/nav_bookings_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_bookings"
                app:tint="#94A3B8" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/nav_chat_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <View
                android:id="@+id/nav_chat_active_bg"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_light_blue"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/nav_chat_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_messages"
                app:tint="#94A3B8" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/nav_profile_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <View
                android:id="@+id/nav_profile_active_bg"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_light_blue"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/nav_profile_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_profile"
                app:tint="@color/sapphire_primary" />
        </FrameLayout>

    </LinearLayout>
</FrameLayout>
