<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:paddingTop="16dp"
    android:paddingBottom="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ====================== CARD 1: Professional Garden Redesign (COMPLETED) ====================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- COMPLETED Pill (top-left) -->
                <TextView
                    android:id="@+id/tvStatus1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_cyan"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="COMPLETED"
                    android:textColor="#047857"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Amount + Date (top-right) -->
                <LinearLayout
                    android:id="@+id/llAmount1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+$450.00"
                        android:textColor="#0F766E"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Oct 12, 2023"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="12dp"
                    android:text="Professional Garden\nRedesign"
                    android:textColor="#1E3A8A"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/llAmount1"
                    app:layout_constraintTop_toBottomOf="@id/tvStatus1" />

                <!-- Customer label -->
                <TextView
                    android:id="@+id/tvCustomer1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Customer: Eleanor Rigby"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle1" />

                <!-- Rating Block (light gray bg) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clRating1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_profile_block_bookings"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/tvCustomer1">

                    <!-- Star + rating + Given label -->
                    <ImageView
                        android:id="@+id/ivStar1"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star_yellow"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvRating1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="4.9"
                        android:textColor="#D97706"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivStar1"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvGiven1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Given"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        app:layout_constraintStart_toEndOf="@id/tvRating1"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <!-- Vertical divider line -->
                    <View
                        android:id="@+id/vDividerRating1"
                        android:layout_width="1dp"
                        android:layout_height="0dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="#D1D5DB"
                        app:layout_constraintStart_toEndOf="@id/tvGiven1"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <!-- Review text -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Exceptional service and\ndetail."
                        android:textColor="#475569"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp"
                        app:layout_constraintStart_toEndOf="@id/vDividerRating1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Action Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/clRating1">

                    <!-- View Details -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_btn_outline_blue"
                        android:gravity="center"
                        android:text="View Details"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- View Earnings -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_btn_teal_solid"
                        android:gravity="center"
                        android:text="View Earnings"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====================== CARD 2: Standard HVAC Maintenance (CANCELLED) ====================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- CANCELLED Pill (top-left) -->
                <TextView
                    android:id="@+id/tvStatus2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_light_red"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="CANCELLED"
                    android:textColor="#DC2626"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Amount + Date (top-right) -->
                <LinearLayout
                    android:id="@+id/llAmount2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textColor="#94A3B8"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="end" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Oct 10, 2023"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="12dp"
                    android:text="Standard HVAC\nMaintenance"
                    android:textColor="#1E3A8A"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/llAmount2"
                    app:layout_constraintTop_toBottomOf="@id/tvStatus2" />

                <!-- Customer label -->
                <TextView
                    android:id="@+id/tvCustomer2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Customer: Thomas Miller"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle2" />

                <!-- Cancellation note (italic) -->
                <TextView
                    android:id="@+id/tvCancelNote2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Cancellation fee not applicable for this booking type."
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:lineSpacingExtra="3dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvCustomer2" />

                <!-- View Cancellation Details Button (full width, outlined) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_btn_outline_blue"
                    android:gravity="center"
                    android:text="View Cancellation Details"
                    android:textColor="#1E3A8A"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/tvCancelNote2" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ====================== CARD 3: Smart Home Hub Installation (COMPLETED) ====================== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- COMPLETED Pill (top-left) -->
                <TextView
                    android:id="@+id/tvStatus3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_cyan"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="COMPLETED"
                    android:textColor="#047857"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Amount + Date (top-right) -->
                <LinearLayout
                    android:id="@+id/llAmount3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+$185.25"
                        android:textColor="#0F766E"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Oct 05, 2023"
                        android:textColor="#9CA3AF"
                        android:textSize="10sp"
                        android:gravity="end" />
                </LinearLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="12dp"
                    android:text="Smart Home Hub\nInstallation"
                    android:textColor="#1E3A8A"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/llAmount3"
                    app:layout_constraintTop_toBottomOf="@id/tvStatus3" />

                <!-- Customer label -->
                <TextView
                    android:id="@+id/tvCustomer3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Customer: Sarah Jenkins"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle3" />

                <!-- Rating Block (light gray bg) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clRating3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_profile_block_bookings"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/tvCustomer3">

                    <ImageView
                        android:id="@+id/ivStar3"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star_yellow"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvRating3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="5.0"
                        android:textColor="#D97706"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivStar3"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvGiven3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Given"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        app:layout_constraintStart_toEndOf="@id/tvRating3"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <View
                        android:id="@+id/vDividerRating3"
                        android:layout_width="1dp"
                        android:layout_height="0dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="#D1D5DB"
                        app:layout_constraintStart_toEndOf="@id/tvGiven3"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Quick and very\nprofessional setup."
                        android:textColor="#475569"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp"
                        app:layout_constraintStart_toEndOf="@id/vDividerRating3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Action Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/clRating3">

                    <!-- View Details -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_btn_outline_blue"
                        android:gravity="center"
                        android:text="View Details"
                        android:textColor="#1E3A8A"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- View Earnings -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_btn_teal_solid"
                        android:gravity="center"
                        android:text="View Earnings"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
