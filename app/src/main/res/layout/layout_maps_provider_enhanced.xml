<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">

    <!-- 1. Google Map Background (Full Screen) -->
    <fragment
        android:id="@+id/provider_map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 2. Top Header & Controls Overlay -->
    <LinearLayout
        android:id="@+id/provider_top_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Header: Avatar, Title, Settings -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:paddingBottom="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/provider_profile_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_alex"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" />

            <TextView
                android:id="@+id/app_title_provider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Civic Pulse"
                android:textColor="@color/sapphire_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/provider_profile_avatar"
                app:layout_constraintStart_toEndOf="@id/provider_profile_avatar"
                app:layout_constraintTop_toTopOf="@id/provider_profile_avatar" />

            <ImageView
                android:id="@+id/btn_settings_provider"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings_outline"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_body_dark" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Search Bar with Location Recenter -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_glass_search_bar"
            android:elevation="4dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/ic_search"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search_grey"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#64748B" />

                <EditText
                    android:id="@+id/provider_search_edit_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:hint="Search for places or jobs"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:textColor="#334155"
                    android:textColorHint="#94A3B8"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toStartOf="@id/ic_recenter_location"
                    app:layout_constraintStart_toEndOf="@id/ic_search" />

                <ImageView
                    android:id="@+id/ic_recenter_location"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_nav_map_final"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/sapphire_primary" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Provider Mode Switch & Filter Chips -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <!-- Mode Switch: Gigs / Community (Left) -->
            <FrameLayout
                android:id="@+id/provider_mode_switch"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_segmented_control"
                android:padding="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_provider_gigs"
                        android:layout_width="80dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_segmented_thumb"
                        android:gravity="center"
                        android:text="Gigs"
                        android:textColor="@color/sapphire_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/btn_provider_community"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Community"
                        android:textColor="@color/text_body_light"
                        android:textSize="14sp" />

                </LinearLayout>
            </FrameLayout>

            <!-- Filter Chips (Right, Horizontal Scroll) -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="16dp"
                android:scrollbars="none"
                app:layout_constraintStart_toEndOf="@id/provider_mode_switch"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingEnd="8dp">

                    <!-- Urgency Filter Chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_urgency"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:text="Urgency"
                        android:textSize="12sp"
                        android:backgroundTint="@color/white"
                        app:chipIcon="@drawable/ic_alarm_orange"
                        app:chipIconSize="16dp"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/border_standard"
                        app:iconStartPadding="4dp"
                        app:closeIconVisible="false"
                        style="@style/Widget.MaterialComponents.Chip.Filter" />

                    <!-- Budget Filter Chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_budget"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:text="Budget"
                        android:textSize="12sp"
                        android:backgroundTint="@color/white"
                        app:chipIcon="@drawable/ic_payment_wallet_blue"
                        app:chipIconSize="16dp"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/border_standard"
                        app:iconStartPadding="4dp"
                        app:closeIconVisible="false"
                        style="@style/Widget.MaterialComponents.Chip.Filter" />

                    <!-- Distance Filter Chip -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="0.5km"
                        android:textSize="12sp"
                        android:backgroundTint="@color/white"
                        app:chipIcon="@drawable/ic_loc_pin_small"
                        app:chipIconSize="16dp"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/border_standard"
                        app:iconStartPadding="4dp"
                        app:closeIconVisible="false"
                        style="@style/Widget.MaterialComponents.Chip.Filter" />

                </LinearLayout>
            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- 3. Bottom Sheet Panel (Draggable) - Core Feature -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/bottom_sheet_coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Bottom Sheet -->
        <com.google.android.material.bottomsheet.BottomSheetBehavior
            android:id="@+id/bottom_sheet_behavior"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            app:behavior_hideable="false"
            app:behavior_peekHeight="72dp"
            app:behavior_saveFlags="none">

        </com.google.android.material.bottomsheet.BottomSheetBehavior>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/provider_bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            app:cardCornerRadius="32dp"
            app:cardElevation="12dp"
            app:strokeWidth="0dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingHorizontal="20dp"
                android:paddingBottom="20dp">

                <!-- Handle / Drag Indicator -->
                <View
                    android:id="@+id/bottom_sheet_handle"
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_bottom_sheet_handle"
                    android:layout_gravity="center_horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Collapsed State: Title + Count -->
                <TextView
                    android:id="@+id/bottom_sheet_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Jobs near you"
                    android:textColor="@color/text_header"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/bottom_sheet_handle" />

                <TextView
                    android:id="@+id/bottom_sheet_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 available"
                    android:textColor="@color/text_subheadline"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/bottom_sheet_title"
                    app:layout_constraintBottom_toBottomOf="@id/bottom_sheet_title" />

                <!-- Scrollable Jobs List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/provider_jobs_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:paddingBottom="8dp"
                    android:scrollbars="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/bottom_sheet_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:itemCount="3" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- 4. Job Detail Card (Floating, Initially Hidden) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/provider_job_detail_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="112dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Job Icon -->
            <ImageView
                android:id="@+id/ic_job_type"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_light_blue"
                android:padding="12dp"
                android:src="@drawable/ic_plumber"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/sapphire_primary" />

            <!-- Job Title -->
            <TextView
                android:id="@+id/job_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Plumbing Repair"
                android:textColor="@color/text_header"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/ic_close_card"
                app:layout_constraintStart_toEndOf="@id/ic_job_type"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Close Button -->
            <ImageView
                android:id="@+id/ic_close_card"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close_grey"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Category Tag -->
            <TextView
                android:id="@+id/tag_gig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_box_pink"
                android:backgroundTint="@color/brand_secondary_light"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="GIG"
                android:textColor="@color/brand_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/job_title"
                app:layout_constraintTop_toBottomOf="@id/job_title" />

            <!-- Distance Tag -->
            <TextView
                android:id="@+id/job_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="0.5km away"
                android:textColor="@color/text_subheadline"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@id/tag_gig"
                app:layout_constraintStart_toEndOf="@id/tag_gig"
                app:layout_constraintTop_toTopOf="@id/tag_gig" />

            <!-- Budget & Urgency Box -->
            <androidx.cardview.widget.CardView
                android:id="@+id/budget_urgency_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/tag_gig">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <!-- Budget Section -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BUDGET"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/job_budget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹500 - 800"
                            android:textColor="@color/text_header"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Urgency Section -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="URGENCY"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/job_urgency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High"
                            android:textColor="@color/brand_success"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Description -->
            <TextView
                android:id="@+id/job_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Pipe repair in kitchen area, needs urgently"
                android:textColor="@color/text_body"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4"
                app:layout_constraintTop_toBottomOf="@id/budget_urgency_box" />

            <!-- Accept Job Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accept_job"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/sapphire_primary"
                android:text="Accept Job"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="textEnd"
                app:layout_constraintTop_toBottomOf="@id/job_description" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 5. Provider Navbar (Bottom) -->
    <include
        android:id="@+id/provider_navbar"
        layout="@layout/layout_floating_navbar_seeker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
