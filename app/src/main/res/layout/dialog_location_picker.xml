<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Handle Bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:gravity="center">
        <View
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_circle_ripple"
            android:alpha="0.4" />
    </FrameLayout>

    <!-- Title Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Choose Delivery Location"
            android:textColor="@color/text_header"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black" />

        <ImageButton
            android:id="@+id/btnCloseLocationPicker"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"
            app:tint="@color/text_muted"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Use Current Location Row -->
    <LinearLayout
        android:id="@+id/rowCurrentLocation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_loc_pin_small"
            app:tint="@color/sapphire_primary"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Use Current Location"
                android:textColor="@color/text_header"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/tvCurrentLocationSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to detect"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressCurrentLocation"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:visibility="gone"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Search Bar -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#F1F5F9"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search_grey"
                app:tint="#64748B" />

            <EditText
                android:id="@+id/etLocationSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search for area, street, or city..."
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="#334155"
                android:textColorHint="#94A3B8"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Search Results List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLocationPredictions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="300dp"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light" />

    <!-- Saved Locations Header -->
    <TextView
        android:id="@+id/headerSavedLocations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SAVED LOCATIONS"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:visibility="gone" />

    <!-- Home Row -->
    <LinearLayout
        android:id="@+id/rowHome"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/brand_primary_light"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_home"
                app:tint="@color/sapphire_primary" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/text_header"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SECTOR 15, GURUGRAM"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/text_muted" />
    </LinearLayout>

    <!-- Work Row -->
    <LinearLayout
        android:id="@+id/rowWork"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FEF3C7"
            app:cardElevation="0dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_briefcase_blue"
                app:tint="#D97706" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Work"
                android:textColor="@color/text_header"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DLF CYBER CITY, GURGAON"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/text_muted" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/dividerLocations"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light"
        android:layout_marginVertical="8dp"
        android:visibility="gone" />

    <!-- Recent Locations Header -->
    <TextView
        android:id="@+id/headerRecentLocations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RECENT"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:visibility="gone" />

    <!-- Recent 1 -->
    <LinearLayout
        android:id="@+id/rowRecent1"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_clock"
            app:tint="@color/text_muted"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sector 21, Gurugram"
                android:textColor="@color/text_header"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 days ago"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/text_muted" />
    </LinearLayout>

    <!-- Recent 2 -->
    <LinearLayout
        android:id="@+id/rowRecent2"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_clock"
            app:tint="@color/text_muted"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connaught Place, Delhi"
                android:textColor="@color/text_header"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 week ago"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/text_muted" />
    </LinearLayout>

    <!-- Bottom Padding -->
    <View
        android:layout_width="match_parent"
        android:layout_height="20dp" />

</LinearLayout>
