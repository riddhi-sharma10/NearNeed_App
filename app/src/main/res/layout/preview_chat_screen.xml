<?xml version="1.0" encoding="utf-8"?>
<!-- DESIGN PREVIEW FILE — Open this in Android Studio's Design tab to see
     how the chat looks with both sent and received messages.
     This layout is NOT used at runtime. The real chat uses activity_chat.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sapphire_neutral"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="16dp"
        android:paddingBottom="100dp">

        <!-- RECEIVED: left-aligned, soft blue tint bg -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="72dp"
            android:paddingBottom="6dp"
            android:gravity="start">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_incoming"
                android:text="Hey! Are you available today?"
                android:textColor="@color/text_body_dark"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- SENT: right-aligned, deep blue bg, white text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="72dp"
            android:paddingBottom="6dp"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_outgoing"
                android:text="Yeah, what's up?"
                android:textColor="@color/text_on_brand"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- RECEIVED -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="72dp"
            android:paddingBottom="6dp"
            android:gravity="start">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_incoming"
                android:text="I need help with the plumbing at my place."
                android:textColor="@color/text_body_dark"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- SENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="72dp"
            android:paddingBottom="6dp"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_outgoing"
                android:text="That would be amazing, thank you!"
                android:textColor="@color/text_on_brand"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- RECEIVED -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="72dp"
            android:paddingBottom="6dp"
            android:gravity="start">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_incoming"
                android:text="I can come by around 3 PM if that works?"
                android:textColor="@color/text_body_dark"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- SENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="72dp"
            android:paddingBottom="6dp"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_outgoing"
                android:text="3 PM works perfectly for me 👍"
                android:textColor="@color/text_on_brand"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- RECEIVED -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="72dp"
            android:paddingBottom="6dp"
            android:gravity="start">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_incoming"
                android:text="Great! Do I need to get any parts?"
                android:textColor="@color/text_body_dark"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- SENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="72dp"
            android:paddingBottom="6dp"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_outgoing"
                android:text="Just bring the wrench set, I have everything else."
                android:textColor="@color/text_on_brand"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- RECEIVED -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="72dp"
            android:paddingBottom="6dp"
            android:gravity="start">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_incoming"
                android:text="Perfect. See you then!"
                android:textColor="@color/text_body_dark"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

        <!-- SENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="72dp"
            android:paddingBottom="6dp"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_outgoing"
                android:text="See you! 🔧"
                android:textColor="@color/text_on_brand"
                android:textSize="15sp"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingTop="12dp" android:paddingBottom="12dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>
