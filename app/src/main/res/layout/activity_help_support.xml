<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:context=".HelpSupportActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_card"
            android:elevation="4dp"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="Back"
                android:src="@drawable/ic_back_arrow"
                app:tint="@color/text_body_dark"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Help &amp; Support"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Frequently Asked Questions"
                    android:textSize="20sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap a question to expand the answer."
                    android:textSize="13sp"
                    android:layout_marginBottom="14dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqPostGigCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqPostGigHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="15dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I post a gig?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqPostGigArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqPostGigAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Open the Home screen, tap the + button, fill in the gig details, then publish it. You can add photos and set the location before posting."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqIdVerifyCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqIdVerifyHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I get ID Verified?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqIdVerifyArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqIdVerifyAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Go to Profile, open ID Verification, and upload the required document and selfie. Review usually completes after the details are checked."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqFeeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqFeeHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Is there a fee for NearNeed?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqFeeArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqFeeAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Creating an account and browsing is free. Some service actions or future premium features may include fees depending on the feature and region."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqLocationCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqLocationHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I change my location?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqLocationArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqLocationAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Open Profile, go to your location settings, and update your service area or city. Your feed and recommendations will refresh after saving."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqScoreCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqScoreHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="What is a 'Neighbour Score'?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqScoreArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqScoreAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Neighbour Score helps summarize trust and activity on the platform. It may be based on profile completeness, responsiveness, and positive interactions."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqReportCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqReportHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I report a user?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqReportArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqReportAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Open the chat or profile for that user, tap the menu options, and choose Report. Please add details so the support team can review it quickly."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqPasswordCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqPasswordHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="15dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I reset my password?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqPasswordArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqPasswordAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Use the login screen's Forgot Password option or contact support if you no longer have access to your phone number."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqNotificationsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqNotificationsHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="15dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I manage notifications?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqNotificationsArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqNotificationsAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Open Settings to choose which alerts you want to receive, including messages, bookings, and updates."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqVisibilityCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqVisibilityHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="15dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I control post visibility?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqVisibilityArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqVisibilityAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="When creating a post, choose the audience and service area carefully. You can edit your post later from the post details screen."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqChatCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqChatHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="15dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I start a chat?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqChatArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqChatAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Open any profile or request card and tap Message to start a conversation. You can also reply directly from the Messages tab."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContactUs"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Contact Us"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary"
                    app:backgroundTint="#C7DFFF"
                    app:cornerRadius="18dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
