<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeColor="#EFF6FF"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Row 1: Status pill + Amount/Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <!-- Status pill -->
            <TextView
                android:id="@+id/tvPastJobStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_completed_soft"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="COMPLETED"
                android:textColor="#0F766E"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Amount + Date column -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPastJobAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+₹450.00"
                    android:textColor="#0F766E"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPastJobDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="Oct 12, 2023"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Job Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvPastJobTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Professional Garden Redesign"
                android:textColor="@color/sapphire_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPastJobBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIG"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_trending_badge"
                android:backgroundTint="#1E3A8A" />
        </LinearLayout>

        <!-- Customer name -->
        <TextView
            android:id="@+id/tvPastJobCustomer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Customer: Eleanor Rigby"
            android:textColor="@color/text_body_light"
            android:textSize="13sp" />

        <!-- ===== COMPLETED SECTION ===== -->
        <LinearLayout
            android:id="@+id/layoutCompleted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Review box (star + text) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_review_box"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp"
                android:padding="12dp"
                android:orientation="horizontal">

                <!-- Star rating badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rating_pill_white_bookings"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="5dp"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_star_yellow"
                        android:layout_marginEnd="3dp" />

                    <TextView
                        android:id="@+id/tvPastJobRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.9"
                        android:textColor="@color/sapphire_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Divider label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Given"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />

                <!-- Review snippet -->
                <TextView
                    android:id="@+id/tvPastJobReview"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Exceptional service and detail."
                    android:textColor="@color/text_subheadline"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

            <!-- Action buttons: Message + View Earnings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPastViewDetails"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Message"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/sapphire_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_nav_messages"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPastViewEarnings"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="View Earnings"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="#0F766E"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- ===== CANCELLED SECTION ===== -->
        <LinearLayout
            android:id="@+id/layoutCancelled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Cancellation note -->
            <TextView
                android:id="@+id/tvCancellationNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="Cancellation fee not applicable for this booking type."
                android:textColor="@color/text_body_light"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:lineSpacingMultiplier="1.3" />

            <!-- View Cancellation Details button -->
            <Button
                android:id="@+id/btnPastViewCancellation"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_btn_grey_outline"
                android:text="View Cancellation Details"
                android:textColor="@color/text_subheadline"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
