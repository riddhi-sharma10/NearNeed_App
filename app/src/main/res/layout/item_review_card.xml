<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/white"
    android:elevation="1dp"
    android:layout_marginVertical="8dp"
    android:padding="12dp"
    android:gravity="center_vertical"
    tools:ignore="HardcodedText,ContentDescription,SpUsage"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/ivReviewerAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_nav_profile"
        android:scaleType="centerCrop"
        app:tint="@color/brand_primary"
        android:layout_marginEnd="12dp" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Name + Rating -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvReviewerName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sarah Johnson"
                android:textColor="@color/text_header"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReviewRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★ 4.5"
                android:textColor="@color/rating_star"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/tvReviewDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 days ago"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp" />

        <!-- Review Text -->
        <TextView
            android:id="@+id/tvReviewText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Very helpful and reliable person. Completed the task on time!"
            android:textColor="@color/text_body"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingExtra="1dp" />

    </LinearLayout>

</LinearLayout>
