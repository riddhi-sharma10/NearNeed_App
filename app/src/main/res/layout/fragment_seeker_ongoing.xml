<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:paddingTop="16dp"
    android:paddingBottom="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- CARD 1: Deep Kitchen Sanitization -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- In Progress Pill -->
                <TextView
                    android:id="@+id/tvStatus1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_in_progress"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="IN PROGRESS"
                    android:textColor="#047857"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Deep Kitchen\nSanitization"
                    android:textColor="#1E3A8A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvStatus1" />

                <!-- Location -->
                <ImageView
                    android:id="@+id/ivLocation1"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="8dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle1"
                    app:tint="#6B7280" />

                <TextView
                    android:id="@+id/tvLocation1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Downtown Loft, Sector 4"
                    android:textColor="#4B5563"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/ivLocation1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivLocation1"
                    app:layout_constraintTop_toTopOf="@id/ivLocation1" />

                <!-- Profile Block (Gray Background) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clProfileBlock1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_profile_block_bookings"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/ivLocation1">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="#DBEAFE"
                        android:src="@android:drawable/ic_menu_camera"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                        app:tint="#1E3A8A" />

                    <TextView
                        android:id="@+id/tvAssignedPro1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="ASSIGNED PRO"
                        android:textColor="#9CA3AF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivProfile1"
                        app:layout_constraintTop_toTopOf="@id/ivProfile1" />

                    <TextView
                        android:id="@+id/tvName1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Sarah Jenkins"
                        android:textColor="#1E3A8A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivProfile1"
                        app:layout_constraintTop_toBottomOf="@id/tvAssignedPro1" />

                    <!-- Rating Pill inside Profile Block -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rating_pill_white_bookings"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@android:drawable/star_on"
                            app:tint="#D97706" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="4.9"
                            android:textColor="#1E3A8A"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Live Map Link -->
                <ImageView
                    android:id="@+id/ivMap1"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="24dp"
                    android:src="@android:drawable/ic_dialog_map"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clProfileBlock1"
                    app:tint="#1E3A8A" />

                <TextView
                    android:id="@+id/tvLiveMap1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Live Map"
                    android:textColor="#1E3A8A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivMap1"
                    app:layout_constraintStart_toEndOf="@id/ivMap1"
                    app:layout_constraintTop_toTopOf="@id/ivMap1" />

                <!-- Buttons Area -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/ivMap1">

                    <!-- Top Row: Chat + Track -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- Chat Button (Cyan) -->
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_button_chat_bookings"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_dialog_email"
                                app:tint="#047857" />
                        </LinearLayout>

                        <!-- Track Live Location Button (Filled Dark Blue) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button_dark_blue_12dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginEnd="8dp"
                                android:src="@android:drawable/ic_menu_send"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Track Live Location"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Update Status Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUpdateStatus1"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Update Status &amp; Pay"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="@color/brand_success"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_check_circle_green"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 2: Afternoon Pet Walk -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- In Progress Pill -->
                <TextView
                    android:id="@+id/tvStatus2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_in_progress"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="IN PROGRESS"
                    android:textColor="#047857"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Afternoon Pet Walk"
                    android:textColor="#1E3A8A"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvStatus2" />

                <!-- Location -->
                <ImageView
                    android:id="@+id/ivLocation2"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="8dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle2"
                    app:tint="#6B7280" />

                <TextView
                    android:id="@+id/tvLocation2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Central Park, West Gate"
                    android:textColor="#4B5563"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/ivLocation2"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivLocation2"
                    app:layout_constraintTop_toTopOf="@id/ivLocation2" />

                <!-- Profile Block (Gray Background) -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/clProfileBlock2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_profile_block_bookings"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/ivLocation2">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="#DBEAFE"
                        android:src="@android:drawable/ic_menu_camera"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                        app:tint="#1E3A8A" />

                    <TextView
                        android:id="@+id/tvAssignedPro2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="ASSIGNED PRO"
                        android:textColor="#9CA3AF"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivProfile2"
                        app:layout_constraintTop_toTopOf="@id/ivProfile2" />

                    <TextView
                        android:id="@+id/tvName2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Marcus Thorne"
                        android:textColor="#1E3A8A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivProfile2"
                        app:layout_constraintTop_toBottomOf="@id/tvAssignedPro2" />

                    <!-- Rating Pill inside Profile Block -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rating_pill_white_bookings"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@android:drawable/star_on"
                            app:tint="#D97706" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="4.8"
                            android:textColor="#1E3A8A"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Live Map Link -->
                <ImageView
                    android:id="@+id/ivMap2"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="24dp"
                    android:src="@android:drawable/ic_dialog_map"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clProfileBlock2"
                    app:tint="#1E3A8A" />

                <TextView
                    android:id="@+id/tvLiveMap2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Live Map"
                    android:textColor="#1E3A8A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivMap2"
                    app:layout_constraintStart_toEndOf="@id/ivMap2"
                    app:layout_constraintTop_toTopOf="@id/ivMap2" />

                <!-- Buttons Area -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/ivMap2">

                    <!-- Top Row: Chat + Track -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- Chat Button (Cyan) -->
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_button_chat_bookings"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_dialog_email"
                                app:tint="#047857" />
                        </LinearLayout>

                        <!-- Track Live Location Button (Filled Dark Blue) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button_dark_blue_12dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginEnd="8dp"
                                android:src="@android:drawable/ic_menu_send"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Track Live Location"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Update Status Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUpdateStatus2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Update Status &amp; Pay"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="@color/brand_success"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_check_circle_green"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
