<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_job_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp"
    android:paddingHorizontal="12dp"
    android:background="?attr/selectableItemBackground"
    android:layout_marginBottom="4dp">

    <!-- Job Icon -->
    <ImageView
        android:id="@+id/item_job_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_circle_light_blue"
        android:padding="10dp"
        android:scaleType="centerInside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Job Title (Bold) -->
    <TextView
        android:id="@+id/item_job_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Plumbing Repair"
        android:textColor="@color/text_header"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/item_job_budget"
        app:layout_constraintStart_toEndOf="@id/item_job_icon"
        app:layout_constraintTop_toTopOf="@id/item_job_icon" />

    <!-- Job Budget (Right Aligned) -->
    <TextView
        android:id="@+id/item_job_budget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹500-800"
        android:textColor="@color/sapphire_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/item_job_title"
        app:layout_constraintBottom_toBottomOf="@id/item_job_title" />

    <!-- Job Description (Secondary) -->
    <TextView
        android:id="@+id/item_job_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:text="Pipe repair in kitchen"
        android:textColor="@color/text_body_dark"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintEnd_toStartOf="@id/item_job_distance"
        app:layout_constraintStart_toEndOf="@id/item_job_icon"
        app:layout_constraintTop_toBottomOf="@id/item_job_title" />

    <!-- Job Distance (Right) -->
    <TextView
        android:id="@+id/item_job_distance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="0.5km"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/item_job_description"
        app:layout_constraintBottom_toBottomOf="@id/item_job_description" />

    <!-- View Post Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_view_post"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:paddingHorizontal="20dp"
        android:text="View Post"
        android:textSize="12sp"
        android:textAllCaps="false"
        app:cornerRadius="18dp"
        app:backgroundTint="@color/sapphire_primary"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/item_job_icon"
        app:layout_constraintBottom_toBottomOf="@id/item_job_description" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_standard"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/item_job_description" />

</androidx.constraintlayout.widget.ConstraintLayout>
