<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <!-- App Bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="-12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back_arrow"
                    android:scaleType="centerInside"
                    app:tint="@color/text_header" />

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="ID Verification"
                    android:textColor="@color/text_header"
                    android:textSize="16sp" />

            </RelativeLayout>

            <!-- Hero Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_glass_main"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp"
                android:elevation="2dp">

                <!-- Shield Icon with circle background -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_circle_light_blue">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_verified_badge"
                        app:tint="@color/brand_primary" />

                </FrameLayout>

                <TextView
                    style="@style/AppHero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Verify your identity"
                    android:textColor="@color/text_header"
                    android:textSize="26sp"
                    android:letterSpacing="-0.02" />

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="NearNeed requires ID verification before you can post or apply for gigs."
                    android:textColor="@color/text_subheadline"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- Why Verify Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_verified_blue_shield"
                android:padding="18dp"
                android:orientation="vertical">

                <!-- WHY VERIFY section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_shield_check"
                        app:tint="@color/brand_primary" />

                    <TextView
                        style="@style/AppHeading.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="WHY VERIFY?"
                        android:textColor="@color/brand_primary"
                        android:textSize="10sp" />

                </LinearLayout>

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="• Build deep trust with neighbors\n• Get a verified badge on your profile\n• Access high-reward Gigs and special tasks"
                    android:textColor="@color/text_header"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_standard"
                    android:layout_marginVertical="14dp" />

                <!-- ACCEPTED IDS section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_id_camera"
                        app:tint="@color/brand_primary" />

                    <TextView
                        style="@style/AppHeading.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="ACCEPTED IDS"
                        android:textColor="@color/brand_primary"
                        android:textSize="10sp" />

                </LinearLayout>

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Aadhaar, PAN, Driving License, Voter ID, Passport"
                    android:textColor="@color/text_header"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Upload Section Label -->
            <TextView
                style="@style/AppHeading.Small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="UPLOAD YOUR ID"
                android:textColor="@color/text_subheadline"
                android:textSize="11sp" />

            <!-- Front Side Upload -->
            <RelativeLayout
                android:id="@+id/cardUploadFront"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_dashed_border"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconFront"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_id_camera"
                        app:tint="@color/brand_primary" />

                    <TextView
                        android:id="@+id/titleFront"
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Front of ID"
                        android:textColor="@color/text_header"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/descFront"
                        style="@style/AppDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear picture, no light reflections."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/tickFront"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="20dp"
                    android:src="@drawable/ic_verified_badge"
                    app:tint="@color/brand_primary"
                    android:visibility="gone" />

            </RelativeLayout>

            <!-- Back Side Upload -->
            <RelativeLayout
                android:id="@+id/cardUploadBack"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_dashed_border"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconBack"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_id_camera"
                        app:tint="@color/brand_primary" />

                    <TextView
                        android:id="@+id/titleBack"
                        style="@style/AppHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Back of ID"
                        android:textColor="@color/text_header"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/descBack"
                        style="@style/AppDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clear picture, horizontally held."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/tickBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="20dp"
                    android:src="@drawable/ic_verified_badge"
                    app:tint="@color/brand_primary"
                    android:visibility="gone" />

            </RelativeLayout>

            <!-- Privacy Note (glass card) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_glass_layered"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical"
                android:elevation="1dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_lock_small"
                    app:tint="@color/brand_primary" />

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Your ID is encrypted and used only for verification. It is never shared with other users."
                    android:textColor="@color/text_subheadline"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>

            <!-- Terms Checkbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical">

                <CheckBox
                    android:id="@+id/cbTerms"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@drawable/sel_custom_checkbox"
                    android:padding="0dp"
                    android:layout_gravity="center_vertical" />

                <TextView
                    android:id="@+id/tvTermsLink"
                    style="@style/AppFormText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="I agree to the Terms &amp; Conditions"
                    android:textColor="@color/text_subheadline"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmit"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Submit for Verification"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="16dp"
                android:elevation="0dp" />

            <!-- Skip -->
            <TextView
                android:id="@+id/btnSkip"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Skip for now"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
