<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeColor="#EFF6FF"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Status + Title -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_in_progress"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="IN PROGRESS"
            android:textColor="#047857"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Service Title"
                android:textColor="#1E3A8A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIG"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_trending_badge"
                android:backgroundTint="#1E3A8A" />
        </LinearLayout>

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="#6B7280" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Location Details"
                android:textColor="#4B5563"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Profile Block -->
        <LinearLayout
            android:id="@+id/profileBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_block_bookings"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="#DBEAFE"
                android:src="@android:drawable/ic_menu_camera"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
                app:tint="#1E3A8A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ASSIGNED PRO"
                    android:textColor="#9CA3AF"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textColor="#1E3A8A"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rating_pill_white_bookings"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/star_on"
                    app:tint="#D97706" />

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="4.8"
                    android:textColor="#1E3A8A"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMessage"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Message"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                app:backgroundTint="#1E3A8A"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconGravity="textStart"
                app:iconPadding="2dp"
                app:iconSize="14dp"
                app:iconTint="@color/white" />

            <!-- Seeker-only: Update Status -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdateStatus"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Update Status"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:visibility="gone"
                app:backgroundTint="@color/brand_success"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconGravity="textStart"
                app:iconPadding="2dp"
                app:iconSize="14dp" />

            <!-- Provider-only: View Details -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewDetails"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="View Details"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="#6366F1"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="16dp" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
