<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <!-- Simple Top Navigation Bar -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="20dp"
            android:layout_marginStart="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/text_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="24dp"
            android:text="Community Preference"
            android:textColor="@color/text_header"
            android:textSize="16sp"
            android:textStyle="bold" />
    </RelativeLayout>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Build your"
                android:textColor="@color/text_header"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Community Profile"
                android:textColor="@color/brand_primary"
                android:textSize="32sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:layout_marginTop="-4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:text="Every helping hand makes a difference. Share your resources and skills to support your neighborhood."
                android:textColor="@color/text_subheadline"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />

            <!-- Card 1: Help Notifications -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_light_blue">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_solid_bell"
                            app:tint="@color/brand_primary" />
                    </FrameLayout>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Help Notifications"
                            android:textColor="@color/text_header"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Push notification when someone needs help"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                    
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/swHelpNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/sel_switch_thumb_primary"
                        app:trackTint="@color/sel_switch_track_primary"
                        app:useMaterialThemeColors="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Notify me via SMS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_light_blue">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_solid_sms"
                            app:tint="@color/brand_primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notify me via SMS"
                            android:textColor="@color/text_header"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="SMS notification to +91 99XXXXX99"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/swSmsNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/sel_switch_thumb_primary"
                        app:trackTint="@color/sel_switch_track_primary"
                        app:useMaterialThemeColors="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Skills Section -->
            <TextView
                style="@style/AppHero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skills/resources you can offer?"
                android:textColor="@color/text_header"
                android:textSize="22sp" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Letting neighbors know how you can help in an emergency."
                android:textColor="@color/text_subheadline"
                android:textSize="14sp" />

            <!-- ChipGroup -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgSkills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">
                
                <com.google.android.material.chip.Chip android:id="@+id/chipCar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Car" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false" />
                <com.google.android.material.chip.Chip android:id="@+id/chipMedical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Medical" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false" />
                <com.google.android.material.chip.Chip android:id="@+id/chipFirstAid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="First Aid" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false" />
                <com.google.android.material.chip.Chip android:id="@+id/chipWater" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Water" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false" />
                <com.google.android.material.chip.Chip android:id="@+id/chipFoodKit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Food/Kit" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false" />
                <com.google.android.material.chip.Chip android:id="@+id/chipSupplies" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Supplies" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false" />
                <com.google.android.material.chip.Chip android:id="@+id/chipShelter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shelter" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false" />
                <com.google.android.material.chip.Chip android:id="@+id/chipTransport" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transport" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false" />
                <com.google.android.material.chip.Chip android:id="@+id/chipTools" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tools" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/sel_chip_bg_primary" app:chipStrokeColor="@color/sel_chip_stroke_primary" app:chipStrokeWidth="1dp" android:textColor="@color/sel_chip_text_primary" app:checkedIconVisible="false"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipOther" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+ Other" style="@style/AppPreferenceChip" app:chipBackgroundColor="@color/white" app:chipStrokeColor="@color/border_standard" app:chipStrokeWidth="1dp" android:textColor="@color/brand_primary" app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Other Skill input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilOtherSkill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/brand_primary"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:hintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOtherSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="What else can you offer?"
                    android:inputType="text"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>
            
            <Space android:layout_width="match_parent" android:layout_height="48dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnter"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Enter"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="16dp"
                android:layout_marginBottom="32dp"
                android:elevation="0dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
