<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="110dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_marginEnd="16dp">

    <!-- Profile Photo -->
    <androidx.cardview.widget.CardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/brand_primary_light">

        <ImageView
            android:id="@+id/ivProviderPhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_image_placeholder" />
    </androidx.cardview.widget.CardView>

    <!-- Verified badge row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/tvProviderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manav Khan"
            android:textColor="@color/text_header"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1" />

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_verified_badge"
            android:layout_marginStart="3dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvProviderCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plumbing Pro"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:layout_marginTop="2dp"
        android:maxLines="1" />

    <!-- Rating + Distance -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="5dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="*"
            android:textColor="@color/rating_star"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/tvProviderRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4.9"
            android:textColor="@color/sapphire_primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="3dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvProviderDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.5 km"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
