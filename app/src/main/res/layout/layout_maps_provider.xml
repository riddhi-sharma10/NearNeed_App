<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">

    <!-- 1. Google Map Background -->
    <fragment
        android:id="@+id/provider_map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 2. Top Header & Chips Overlay -->
    <LinearLayout
        android:id="@+id/provider_top_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Header: Avatar, Title, Settings -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/provider_profile_avatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_alex"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" />

            <TextView
                android:id="@+id/app_title_provider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Civic Pulse"
                android:textColor="@color/sapphire_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/provider_profile_avatar"
                app:layout_constraintStart_toEndOf="@id/provider_profile_avatar"
                app:layout_constraintTop_toTopOf="@id/provider_profile_avatar" />

            <ImageView
                android:id="@+id/btn_settings_provider"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings_outline"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_body_dark" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Provider Switch: Gigs / Community -->
        <FrameLayout
            android:id="@+id/provider_mode_switch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/bg_segmented_control"
            android:padding="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_provider_gigs"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_segmented_thumb"
                    android:gravity="center"
                    android:text="Gigs"
                    android:textColor="@color/sapphire_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_provider_community"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Community"
                    android:textColor="@color/text_body_light" />

            </LinearLayout>
        </FrameLayout>

        <!-- Provider Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/provider_filter_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                app:singleLine="true"
                app:chipSpacingHorizontal="8dp">
                
                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Urgency"
                    android:backgroundTint="@color/white"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/border_standard"
                    app:chipIcon="@drawable/ic_alarm_orange" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Budget"
                    android:backgroundTint="@color/white"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/border_standard"
                    app:chipIcon="@drawable/ic_payment_wallet_blue" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.5km"
                    android:backgroundTint="@color/white"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/border_standard"
                    app:chipIcon="@drawable/ic_loc_pin_small" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

    </LinearLayout>

    <!-- 3. Provider Info Card (Job Request Details) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/provider_info_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="112dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:visibility="gone"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ic_job_type"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_light_blue"
                android:padding="12dp"
                android:src="@drawable/ic_plumber"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/sapphire_primary" />

            <TextView
                android:id="@+id/job_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Plumbing Repair"
                android:textColor="@color/text_header"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/ic_close_card"
                app:layout_constraintStart_toEndOf="@id/ic_job_type"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ic_close_card"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close_grey"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tag_gig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_box_pink"
                android:backgroundTint="@color/brand_secondary_light"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="GIG"
                android:textColor="@color/brand_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/job_title"
                app:layout_constraintTop_toBottomOf="@id/job_title" />

            <TextView
                android:id="@+id/job_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="0.5km away"
                android:textColor="@color/text_subheadline"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="@id/tag_gig"
                app:layout_constraintStart_toEndOf="@id/tag_gig"
                app:layout_constraintTop_toTopOf="@id/tag_gig" />

            <androidx.cardview.widget.CardView
                android:id="@+id/budget_urgency_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/ic_job_type">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BUDGET RANGE"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/job_budget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹500 - 800"
                            android:textColor="@color/text_header"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RESPONSE"
                            android:textColor="@color/text_muted"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/job_urgency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High Urgency"
                            android:textColor="@color/brand_success"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accept_job"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/sapphire_primary"
                android:text="Accept Job"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="28dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="textEnd"
                app:layout_constraintTop_toBottomOf="@id/budget_urgency_box" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 4. Provider Navbar (Injected or standard) -->
    <include
        android:id="@+id/provider_navbar"
        layout="@layout/layout_floating_navbar_seeker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
