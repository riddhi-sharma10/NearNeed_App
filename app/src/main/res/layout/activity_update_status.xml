<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Update Status"
                    android:textColor="@color/text_header"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black" />

                <ImageView
                    android:id="@+id/btnClose"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_close"
                    android:contentDescription="@null"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/text_muted" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Is the task done?"
                android:textColor="@color/text_header"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Status Buttons Group -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatusCompleted"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Yes, Task is Done"
                    android:textColor="@color/text_muted"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:layout_marginBottom="12dp"
                    app:icon="@drawable/ic_check_circle_green"
                    app:iconTint="@color/text_muted"
                    app:iconPadding="12dp"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/divider_subtle"
                    app:strokeWidth="1dp"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatusProgress"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="No, Still in Progress"
                    android:textColor="@color/text_muted"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:layout_marginBottom="12dp"
                    app:icon="@drawable/ic_clock"
                    app:iconTint="@color/text_muted"
                    app:iconPadding="12dp"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/divider_subtle"
                    app:strokeWidth="1dp"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatusOnHold"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Not Started Yet"
                    android:textColor="@color/text_muted"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:layout_marginBottom="12dp"
                    app:icon="@drawable/ic_calendar_nav"
                    app:iconTint="@color/text_muted"
                    app:iconPadding="12dp"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/divider_subtle"
                    app:strokeWidth="1dp"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatusCancelled"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Cancelled"
                    android:textColor="@color/text_muted"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    app:icon="@drawable/ic_close"
                    app:iconTint="@color/text_muted"
                    app:iconPadding="12dp"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/divider_subtle"
                    app:strokeWidth="1dp"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <!-- Cancellation Reason (Hidden by default) -->
            <LinearLayout
                android:id="@+id/layoutCancellationReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reason for Cancellation"
                    android:textColor="@color/text_header"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="@color/sapphire_primary"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="#F9FAFB">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCancellationReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tell us what happened..."
                        android:textColor="@color/text_header"
                        android:minLines="3"
                        android:gravity="top|start" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Payment Options (Hidden by default) -->
            <LinearLayout
                android:id="@+id/layoutPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Payment Method"
                    android:textColor="@color/text_header"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- UPI Option -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPayUPI"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/divider_subtle"
                        app:strokeWidth="1dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">
                            
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_payment_wallet_blue"
                                app:tint="@color/text_muted"
                                android:layout_marginBottom="8dp"/>
                                
                            <TextView
                                android:id="@+id/tvUpiLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Online / UPI"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Cash Option -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPayCash"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/divider_subtle"
                        app:strokeWidth="1dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">
                            
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_cash_icon"
                                app:tint="@color/text_muted"
                                android:layout_marginBottom="8dp"/>
                                
                            <TextView
                                android:id="@+id/tvCashLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cash on Site"
                                android:textColor="@color/text_muted"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <!-- Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitStatus"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Confirm Selection"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                app:backgroundTint="@color/sapphire_primary"
                app:cornerRadius="14dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
