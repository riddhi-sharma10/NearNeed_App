<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:context=".HelpSupportActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_card"
            android:elevation="4dp"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="-12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="centerInside"
                android:clickable="true"
                android:contentDescription="Back"
                android:src="@drawable/ic_back_arrow"
                app:tint="@color/text_body_dark"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                style="@style/AppHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Help &amp; Support"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:padding="16dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/AppHeading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Frequently Asked Questions"
                    android:textSize="20sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    style="@style/AppDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap a question to expand the answer."
                    android:textSize="13sp"
                    android:layout_marginBottom="14dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqPostGigCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqPostGigHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="15dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I post a request?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqPostGigArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqPostGigAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Tap the '+' button on the Home screen. You can choose to post a paid 'Gig' or a free 'Community' request, set the location, and wait for nearby Providers."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqIdVerifyCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqIdVerifyHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I get ID Verified?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqIdVerifyArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqIdVerifyAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Go to your Profile and tap 'ID Verification'. Upload your Aadhaar or PAN card along with a selfie. Verified users get a badge and receive more responses."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqFeeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqFeeHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How does payment work?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqFeeArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqFeeAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Currently, you pay the Provider directly via UPI or Cash once the job is completed to your satisfaction. NearNeed does not hold your money."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqLocationCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqLocationHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How does the Map work?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqLocationArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqLocationAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="NearNeed uses location services to find skilled workers near you. You can update your service area in your Profile to see gigs closer to home."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqScoreCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqScoreHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do ratings work?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqScoreArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqScoreAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="After a gig is completed, both the Seeker and the Provider can rate each other from 1 to 5 stars. High ratings build your community reputation!"
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqReportCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqReportHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="14dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I report an issue?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqReportArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqReportAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Open the chat or profile of the user, tap the menu, and select 'Report'. Our team reviews all reports within 24 hours to ensure platform safety."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqNotificationsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqNotificationsHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="15dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I cancel a booking?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqNotificationsArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqNotificationsAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Go to the 'My Bookings' tab, select your Ongoing or Upcoming booking, and tap 'Cancel Booking'. Please message the Provider beforehand."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/faqChatCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border_standard"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/faqChatHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="15dp">

                            <TextView
                                style="@style/AppFormText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="How do I communicate safely?"
                                android:textColor="@color/text_header"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:id="@+id/faqChatArrow"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_muted" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/faqChatAnswer"
                            style="@style/AppDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="16dp"
                            android:paddingBottom="16dp"
                            android:text="Once a booking is confirmed, an in-app chat is created automatically. We recommend keeping all conversations inside NearNeed for your safety."
                            android:textSize="14sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContactUs"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Contact Us"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/brand_primary"
                    app:backgroundTint="#C7DFFF"
                    app:cornerRadius="18dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

