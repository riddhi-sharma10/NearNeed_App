<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    tools:ignore="HardcodedText,ContentDescription,SpUsage">

    <!-- App Bar -->
    <RelativeLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="@color/surface_background"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="-12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/brand_primary" />

        <TextView
            style="@style/AppHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Professional Setup"
            android:textColor="@color/text_header"
            android:textSize="16sp" />

    </RelativeLayout>

    <!-- Divider -->
    <View
        android:id="@+id/dividerBar"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light"
        app:layout_constraintTop_toBottomOf="@id/appBar" />

    <!-- Scrollable Body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/dividerBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <!-- ── Hero ── -->
            <TextView
                style="@style/AppHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Build your"
                android:textColor="@color/text_header"
                android:textSize="30sp"
                android:letterSpacing="-0.02" />

            <TextView
                style="@style/AppHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Professional Profile"
                android:textColor="@color/brand_primary"
                android:textSize="30sp"
                android:letterSpacing="-0.02" />

            <TextView
                style="@style/AppDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Configure your services and availability to start receiving high-quality gig invitations."
                android:textColor="@color/text_subheadline"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp" />

            <!-- ── Service Categories ── -->
            <TextView
                android:id="@+id/tvCategoryHeader"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Service Categories"
                android:textColor="@color/text_header"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvCategoryError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Select at least one service category"
                android:textColor="#FF0000"
                android:textSize="13sp"
                android:textStyle="normal"
                android:visibility="gone" />

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipPlumbing"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Plumbing"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipElectrical"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Electrical"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipCarpentry"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Carpentry"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipPainting"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Painting"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipAppliance"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Appliance"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipCleaning"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Cleaning"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipGardening"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Gardening"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipAssembly"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Assembly"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipOther"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:paddingHorizontal="4dp"
                    android:text="Other"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ── Service Description ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Service Description"
                android:textColor="@color/text_header"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etServiceDescription"
                style="@style/AppFormText"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field"
                android:gravity="top|start"
                android:hint="Tell us about the specific services you offer..."
                android:textColorHint="@color/text_muted"
                android:inputType="textMultiLine"
                android:maxLines="5"
                android:padding="14dp"
                android:scrollbars="vertical"
                android:textColor="@color/text_header"
                android:textSize="14sp" />

            <!-- ── Experience Level ── -->
            <TextView
                android:id="@+id/tvExperienceHeader"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Experience Level"
                android:textColor="@color/text_header"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvExperienceError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Select your experience level"
                android:textColor="#FF0000"
                android:textSize="13sp"
                android:textStyle="normal"
                android:visibility="gone" />

            <!-- Exp Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/expLow"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:text="0-2 yrs"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/expMid"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:text="2-5 yrs"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Exp Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/expHigh"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:text="5-10 yrs"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/expMax"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:text="10+ yrs"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ── Availability Schedule ── -->
            <TextView
                android:id="@+id/tvDaysHeader"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Availability Schedule"
                android:textColor="@color/text_header"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvDaysError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Select your available days"
                android:textColor="#FF0000"
                android:textSize="13sp"
                android:textStyle="normal"
                android:visibility="gone" />

            <TextView
                style="@style/AppDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Weekly Availability"
                android:textColor="@color/text_subheadline"
                android:textSize="13sp" />

            <!-- Day Row: Sun Mon Tue Wed Thu Fri Sat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/daySun"
                    style="@style/AppFormText"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_unselected_uniform"
                    android:gravity="center"
                    android:text="Sun"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dayMon"
                    style="@style/AppFormText"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_circle_selected_uniform"
                    android:gravity="center"
                    android:text="Mon"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dayTue"
                    style="@style/AppFormText"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_circle_selected_uniform"
                    android:gravity="center"
                    android:text="Tue"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dayWed"
                    style="@style/AppFormText"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_circle_selected_uniform"
                    android:gravity="center"
                    android:text="Wed"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                
                <TextView
                    android:id="@+id/dayThu"
                    style="@style/AppFormText"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_circle_selected_uniform"
                    android:gravity="center"
                    android:text="Thu"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dayFri"
                    style="@style/AppFormText"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_circle_selected_uniform"
                    android:gravity="center"
                    android:text="Fri"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/daySat"
                    style="@style/AppFormText"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_circle_unselected_uniform"
                    android:gravity="center"
                    android:text="Sat"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Preferred Time Slots -->
            <TextView
                android:id="@+id/tvTimeSlotsHeader"
                style="@style/AppDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Preferred Time Slots"
                android:textColor="@color/text_subheadline"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTimeSlotsError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Select at least one time preferred slot"
                android:textColor="#FF0000"
                android:textSize="13sp"
                android:textStyle="normal"
                android:visibility="gone" />

            <!-- Slot Row 1: Morning, Afternoon, Evening -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/slotMorning"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:text="Morning"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/slotAfternoon"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:text="Afternoon"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/slotEvening"
                    style="@style/AppFormText"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chip_unselected_uniform"
                    android:gravity="center"
                    android:text="Evening"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>



            <!-- ── Start Time ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Start Time"
                android:textColor="@color/text_header"
                android:textSize="14sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field">

                <TextView
                    android:id="@+id/tvStartTime"
                    style="@style/AppFormText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:text="08:00 AM"
                    android:textColor="@color/text_header"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_alarm_orange"
                    app:tint="@color/text_muted" />

            </RelativeLayout>

            <!-- ── End Time ── -->
            <TextView
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="End Time"
                android:textColor="@color/text_header"
                android:textSize="14sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_field">

                <TextView
                    android:id="@+id/tvEndTime"
                    style="@style/AppFormText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:text="06:00 PM"
                    android:textColor="@color/text_header"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_alarm_orange"
                    app:tint="@color/text_muted" />

            </RelativeLayout>

            <!-- ── Trust & Verification ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_glass_main"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_shield_check"
                        app:tint="@color/brand_success" />

                    <TextView
                        style="@style/AppHeading"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Trust &amp; Verification"
                        android:textColor="@color/text_header"
                        android:textSize="16sp" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_light"
                    android:layout_marginVertical="14dp" />

                <!-- Terms Checkbox row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbTerms"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:button="@drawable/sel_custom_checkbox"
                        android:buttonTint="@null"
                        app:buttonTint="@null"
                        android:padding="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            style="@style/AppHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Agreement to Terms"
                            android:textColor="@color/text_header"
                            android:textSize="14sp" />

                        <TextView
                            style="@style/AppDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="I agree to the Provider Code of Conduct and Service Level Agreements."
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ── Continue Button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                style="@style/AppHeading"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:elevation="0dp"
                android:text="Continue"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- SUCCESS OVERLAY (Redesigned to match image 2 style) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_success_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="gone"
        android:elevation="100dp">

        <!-- CLOSE BUTTON -->
        <ImageButton
            android:id="@+id/btnSuccessClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_circle_light_blue"
            android:backgroundTint="#F8FAFC"
            android:padding="12dp"
            android:src="@drawable/ic_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#64748B" />

        <!-- CENTERED CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- SUCCESS ICON CIRCLE -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp">

                <!-- Outer soft glow -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.2"
                    android:background="@drawable/bg_circle_light_blue"
                    android:backgroundTint="#2563EB" />

                <!-- Inner solid blue circle -->
                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_light_blue"
                    android:backgroundTint="#2563EB" />

                <!-- White check icon -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check_solid_white" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:fontFamily="sans-serif-black"
                android:text="Success!"
                android:textColor="#0F172A"
                android:textSize="26sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Your community preferences have been updated.\nYou're all set to go!"
                android:textColor="#64748B"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-bold"
                android:text="Status: Active Profile"
                android:textColor="#2563EB"
                android:textSize="14sp" />

            <!-- ACTION BUTTONS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSuccessHome"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="48dp"
                android:fontFamily="sans-serif-black"
                android:text="Back to Home"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="#004B73"
                app:cornerRadius="18dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSuccessProfile"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-black"
                android:text="View Profile"
                android:textAllCaps="false"
                android:textColor="#2563EB"
                android:textSize="15sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
