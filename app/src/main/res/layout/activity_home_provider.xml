<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER & GREETING RESTRUCTURED -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Hello"
                        android:textColor="@color/text_header"
                        android:textSize="30sp"
                        android:letterSpacing="-0.02" />

                    <!-- LOCATION SECTION -->
                    <LinearLayout
                        android:id="@+id/locationSection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_ripple_location"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:paddingStart="2dp"
                        android:paddingEnd="4dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_loc_pin_small"
                            app:tint="@color/sapphire_primary" />

                        <TextView
                            android:id="@+id/tvDeliveryLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="DELIVER TO: HOME - SECTOR 15..."
                            android:textColor="@color/sapphire_primary"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.05" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/ic_dropdown_small"
                            app:tint="@color/sapphire_primary" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:text="Welcome back. Everything is in order for your upcoming tasks."
                        android:textColor="@color/text_subheadline"
                        android:textSize="14sp"
                        android:alpha="0.9" />

                </LinearLayout>

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_circle_solid_white"
                    android:elevation="3dp">

                    <ImageView
                        android:id="@+id/ivDashboardNotifications"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="Notifications"
                        android:src="@drawable/ic_bell"
                        app:tint="@color/text_header" />

                    <TextView
                        android:id="@+id/tvDashboardNotificationBadge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_notification_badge"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:visibility="gone" />
                </FrameLayout>
            </RelativeLayout>

            <!-- Role toggle (Seeker / Provider) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <!-- Section Label -->
                <TextView
                    style="@style/TextAppearance.NearNeed.SectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR MODE:"
                    android:layout_marginBottom="12dp" />

                <!-- Toggle Control -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_segmented_control"
                    android:padding="4dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tab_seeker"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="20dp"
                        android:gravity="center"
                        android:text="Seeker"
                        android:textColor="@color/text_muted"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tab_provider"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="20dp"
                        android:background="@drawable/bg_seeker_tab_active"
                        android:gravity="center"
                        android:text="Provider"
                        android:textColor="@color/brand_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Helper Text -->
                <TextView
                    style="@style/TextAppearance.NearNeed.HelperText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Switch between requesting services and offering your skills" />
            </LinearLayout>

            <!-- SEARCH BAR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#E2E8F0"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search_grey"
                        app:tint="#64748B" />

                    <EditText
                        android:id="@+id/searchEditText"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Search for requests..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:singleLine="true"
                        android:textColor="#334155"
                        android:textColorHint="#64748B"
                        android:textSize="14sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvSearchEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:text="No matching requests found."
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- EARNINGS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/earningsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/provider_earnings_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="26dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08"
                        android:text="@string/earnings_mtd"
                        android:textColor="#065F46"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_home_provider_earnings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/earnings_amount"
                        android:textColor="@color/black"
                        android:textSize="36sp"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        app:drawableStartCompat="@drawable/ic_trending_up"
                        android:drawablePadding="6dp"
                        app:drawableTint="#065F46"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/earnings_growth"
                        android:textColor="#065F46"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STATS GRID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statsGridActiveJobs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/active_jobs_label"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_home_provider_active_jobs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif-black"
                            android:text="@string/active_jobs_count"
                            android:textColor="@color/sapphire_primary"
                            android:textSize="24sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statsGridRating"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/rating_label"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_home_provider_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:fontFamily="sans-serif-black"
                            android:text="@string/rating_value"
                            android:textColor="@color/sapphire_primary"
                            android:textSize="24sp"
                            app:drawableEndCompat="@drawable/ic_star_yellow"
                            android:drawablePadding="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- POST COMMUNITY REQUEST BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPostCommunityRequest"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="@string/txt_btn_community_post"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/sapphire_primary"
                app:cornerRadius="24dp"
                app:elevation="4dp" />

            <!-- TODAY'S SCHEDULE -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <TextView
                    android:id="@+id/scheduleTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/viewCalendar"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/today_schedule"
                    android:textColor="@color/text_header"
                    android:textSize="19sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:id="@+id/viewCalendar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/view_calendar"
                        android:textColor="@color/sapphire_primary"
                        android:textSize="13sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:scaleType="centerInside"
                        android:contentDescription="@null" />
                </LinearLayout>
            </RelativeLayout>

            <!-- SCHEDULE ITEMS REAL-TIME RECYCLER -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProviderSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_provider_schedule" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/time_02_00"
                        android:textColor="@color/text_header"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/time_pm"
                        android:textColor="@color/provider_schedule_time_text"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginStart="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <View android:id="@+id/borderGreen" android:layout_width="4dp" android:layout_height="50dp" android:layout_centerVertical="true" android:layout_marginStart="2dp" android:background="@drawable/bg_dot_green" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="14dp" android:layout_toEndOf="@id/borderGreen" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:text="@string/job_garden" android:textColor="@color/text_header" android:textSize="15sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" app:drawableStartCompat="@drawable/ic_loc_pin_small" android:drawablePadding="4dp" app:drawableTint="#64748B" android:fontFamily="sans-serif-medium" android:text="@string/loc_riverside" android:textColor="#64748B" android:textSize="13sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- REQUESTS NEARBY -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <TextView
                    android:id="@+id/requestsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/viewAllRequestsContainer"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/requests_nearby"
                    android:textColor="@color/text_header"
                    android:textSize="19sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:id="@+id/viewAllRequestsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="@color/sapphire_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/sapphire_primary"
                        android:scaleType="centerInside" />
                </LinearLayout>
            </RelativeLayout>

            <!-- REQUEST CARDS - HORIZONTAL SCROLL -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvNearbyRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="2"
                tools:listitem="@layout/item_request_card" />

            <!-- COMMUNITY VOLUNTEERING SECTION -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp">

                <TextView
                    android:id="@+id/tvCommunityVolunteeringTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/viewAllCommunityContainer"
                    android:fontFamily="sans-serif-black"
                    android:text="Community Volunteering"
                    android:textColor="@color/text_header"
                    android:textSize="19sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:id="@+id/viewAllCommunityContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="@color/brand_success"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/brand_success"
                        android:scaleType="centerInside" />
                </LinearLayout>
            </RelativeLayout>

            <!-- COMMUNITY POST CARDS - HORIZONTAL SCROLL -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCommunityVolunteering"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="2"
                tools:listitem="@layout/item_community_post_card" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#F1F5F9"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_ai_chat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="110dp"
        android:src="@drawable/ic_chat_outline"
        app:backgroundTint="@color/brand_primary"
        app:tint="@color/white"
        app:elevation="6dp" />

    <include
        android:id="@+id/floatingNavbar"
        layout="@layout/layout_main_navbar_page" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
