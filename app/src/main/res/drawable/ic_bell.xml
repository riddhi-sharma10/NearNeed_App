<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
        Sophisticated minimal bell icon.
        Outline style with a dot clapper — no harsh fills.
        Color is applied via app:tint in the layout, so paths use white here.
    -->

    <!-- Bell body: rounded top dome + straight sides + flared base -->
    <path
        android:pathData="
            M12,2
            C8.686,2 6,4.686 6,8
            L6,13
            L4.5,15
            C4.188,15.5 4.5,16 5,16
            L19,16
            C19.5,16 19.812,15.5 19.5,15
            L18,13
            L18,8
            C18,4.686 15.314,2 12,2 Z"
        android:fillColor="@color/white"
        android:fillAlpha="0.15"
        android:strokeColor="@color/white"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Clapper / notification dot at bottom -->
    <path
        android:pathData="M10,16 C10,17.105 10.895,18 12,18 C13.105,18 14,17.105 14,16"
        android:fillColor="#00000000"
        android:strokeColor="@color/white"
        android:strokeWidth="1.6"
        android:strokeLineCap="round" />

    <!-- Subtle dot at top (signal / unread indicator) -->
    <path
        android:pathData="M15,4.5 A1,1 0 1,1 16.999,4.5 A1,1 0 1,1 15,4.5 Z"
        android:fillColor="@color/sapphire_tertiary"
        android:strokeColor="#00000000"
        android:strokeWidth="0" />

</vector>
