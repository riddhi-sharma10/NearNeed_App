<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingVertical="16dp">

    <!-- Timeline Column -->
    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Status Icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="#EDF2FF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivStatusIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_circle_green"
                app:tint="@color/sapphire_primary" />
        </androidx.cardview.widget.CardView>

        <!-- Timeline Line -->
        <ImageView
            android:id="@+id/ivTimelineLine"
            android:layout_width="2dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="#E5E7EB" />
    </LinearLayout>

    <!-- Status Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStatusType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IN PROGRESS"
            android:textColor="@color/sapphire_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvStatusDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Work started on the assigned task"
            android:textColor="@color/text_body"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:lineHeight="18sp" />

        <TextView
            android:id="@+id/tvStatusTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oct 24, 2023 • 10:30 AM"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</LinearLayout>
