<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/white">

    <!-- Top Bar - Match MessagesFragment styling -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingHorizontal="24dp"
        android:paddingTop="54dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back_arrow"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Back"
            android:scaleType="centerInside"
            android:layout_marginEnd="8dp"
            app:tint="@color/brand_primary" />

        <!-- Avatar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="#CCD6E6"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/ivProfilePic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_nav_profile"
                android:scaleType="centerCrop"
                app:tint="@color/brand_primary" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Name + Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvChatName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rachel"
                android:textColor="@color/text_header"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <View
                    android:id="@+id/vOnlineDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_green"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvChatStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/chatDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- Chat Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        tools:listitem="@layout/item_chat_preview_pair"
        tools:itemCount="3"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintTop_toBottomOf="@id/chatDivider" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintTop_toBottomOf="@id/chatDivider">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start a conversation"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Say hello and begin the conversation"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- Bottom Input Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_card"
        android:animateLayoutChanges="true"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Attachment -->
        <ImageView
            android:id="@+id/btnAdd"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            app:tint="@color/brand_secondary" />

        <!-- Recording Tab (Hidden by default) -->
        <LinearLayout
            android:id="@+id/llRecordingTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginEnd="8dp">

            <View
                android:id="@+id/vRecordDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:backgroundTint="@color/brand_error_solid"
                android:background="@drawable/bg_dot_green" />

            <TextView
                android:id="@+id/tvRecordingTime"
                style="@style/AppFormText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="0:00"
                android:textSize="15sp"
                android:textColor="@color/brand_error_solid"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                style="@style/AppDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt; Slide to cancel"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Input pill wrapper -->
        <FrameLayout
            android:id="@+id/flInputWrapper"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_chat_input_pill"
                android:paddingBottom="4dp">

                <!-- Image Preview Area -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cvImagePreview"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/ivSelectedImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />

                        <ImageView
                            android:id="@+id/btnRemoveImage"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_circle_dark_overlay"
                            android:src="@android:drawable/ic_menu_close_clear_cancel"
                            android:padding="4dp"
                            app:tint="@android:color/white" />
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/etMessageInput"
                        style="@style/AppFormText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:hint="Type a message..."
                        android:textColor="@color/text_body_dark"
                        android:textColorHint="@color/text_placeholder"
                        android:maxLines="4"
                        android:paddingStart="12dp"
                        android:paddingTop="11dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="11dp"
                        android:textSize="15sp"
                        android:inputType="textMultiLine" />
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Mic Button -->
        <ImageView
            android:id="@+id/btnMic"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_mic_blue"
            android:background="@drawable/bg_circle_light_blue"
            android:padding="10dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            app:tint="@color/brand_secondary" />

        <!-- Send Button -->
        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_blue_solid"
            android:backgroundTint="@color/brand_primary"
            android:src="@drawable/ic_send_modern"
            android:padding="11dp"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            app:tint="@color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
