<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_response_card"
    android:elevation="2dp"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="0dp"
    android:padding="16dp"
    android:layoutDirection="ltr"
    tools:ignore="HardcodedText,ContentDescription,SpUsage"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Header: Avatar + Name + Rating + Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/ivApplicantAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_nav_profile"
            android:scaleType="centerCrop"
            app:tint="@color/brand_primary"
            android:layout_marginEnd="12dp" />

        <!-- Name + Rating -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvApplicantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="@color/text_header"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvApplicantRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★ 4.5"
                android:textColor="@color/rating_star"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Contact Actions in Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginStart="8dp">

            <ImageButton
                android:id="@+id/btnCallApplicant"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_circle_light_blue"
                android:contentDescription="Call applicant"
                android:padding="8dp"
                android:src="@drawable/ic_phone_outline"
                app:tint="@color/sapphire_primary" />

            <ImageButton
                android:id="@+id/btnMessageApplicant"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_circle_light_blue"
                android:contentDescription="Message applicant"
                android:padding="8dp"
                android:src="@drawable/ic_nav_messages"
                app:tint="@color/sapphire_primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Message -->
    <TextView
        android:id="@+id/tvApplicantMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="I can definitely help with this task. Very experienced in this area."
        android:textColor="@color/text_body"
        android:textSize="14sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="12dp" />

    <!-- Explicit Price Row -->
    <LinearLayout
        android:id="@+id/llPriceApplied"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp"
        android:padding="10dp"
        android:background="@drawable/bg_glass_search_bar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price Applied"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPriceAppliedValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="₹250"
            android:textColor="@color/sapphire_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Location + Time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_loc_pin_small"
            app:tint="@color/brand_secondary"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvApplicantLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 km away"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvAppliedTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 hours ago"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Budget Card (visible only for gigs) -->
    <LinearLayout
        android:id="@+id/llBudgetCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_glass_search_bar"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPLIED FOR"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProposedBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹250"
                android:textColor="@color/text_header"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAYMENT"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPaymentMethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash"
                android:textColor="@color/text_header"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccept"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="Accept"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:backgroundTint="@color/sapphire_primary"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDecline"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="Decline"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="24dp"
                app:strokeColor="@color/sapphire_primary"
                app:strokeWidth="1dp" />

    </LinearLayout>

</LinearLayout>
