<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:paddingTop="16dp"
    android:paddingBottom="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- CARD 1: Deep Carpet Cleaning -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header area with faint background -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F8FAFC"
                    android:paddingTop="20dp"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:id="@+id/tvTitle1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Deep Carpet Cleaning"
                        android:textColor="#1E3A8A"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivChat1"
                        android:layout_marginEnd="12dp" />

                    <!-- Status dot & text -->
                    <View
                        android:id="@+id/vStatusDot1"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_teal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle1"
                        app:layout_constraintBottom_toBottomOf="@+id/tvStatus1"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvStatus1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginTop="8dp"
                        android:text="IN PROGRESS"
                        android:textColor="#0F766E"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/vStatusDot1"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle1" />

                    <ImageView
                        android:id="@+id/ivChat1"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_messages_active"
                        app:tint="#1E3A8A"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Body Area -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="20dp">

                    <!-- Avatar Profile Block -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/avatar_sarah"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

                    <TextView
                        android:id="@+id/tvCustomerLabel1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Customer"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        app:layout_constraintStart_toEndOf="@id/ivProfile1"
                        app:layout_constraintTop_toTopOf="@id/ivProfile1"
                        app:layout_constraintBottom_toTopOf="@+id/tvName1"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvName1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Sarah Jenkins"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivProfile1"
                        app:layout_constraintTop_toBottomOf="@id/tvCustomerLabel1"
                        app:layout_constraintBottom_toBottomOf="@id/ivProfile1" />

                    <!-- Location Block -->
                    <ImageView
                        android:id="@+id/ivLocation1"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/ic_nav_map"
                        app:tint="#0F766E"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivProfile1" />

                    <TextView
                        android:id="@+id/tvLocation1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="20dp"
                        android:text="4522 Oakwood Drive, Suite 102\nNorth Arlington, VA 22207"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        app:layout_constraintStart_toEndOf="@id/ivLocation1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivProfile1" />

                    <!-- Elapsed Time Section -->
                    <TextView
                        android:id="@+id/tvElapsedLabel1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="ELAPSED TIME"
                        android:textColor="#475569"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLocation1" />

                    <TextView
                        android:id="@+id/tvTimer1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="01:42:15"
                        android:textColor="#1E3A8A"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvElapsedLabel1" />

                    <TextView
                        android:id="@+id/tvPercent1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="75% Done"
                        android:textColor="#0F766E"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/tvTimer1"
                        android:layout_marginBottom="4dp"/>

                    <!-- Progress Bar -->
                    <View
                        android:id="@+id/vProgressBase1"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_progress_bar_base_bookings"
                        app:layout_constraintTop_toBottomOf="@id/tvTimer1" />

                    <View
                        android:id="@+id/vProgressFill1"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:background="@drawable/bg_progress_bar_provider_fill"
                        app:layout_constraintBottom_toBottomOf="@id/vProgressBase1"
                        app:layout_constraintStart_toStartOf="@id/vProgressBase1"
                        app:layout_constraintTop_toTopOf="@id/vProgressBase1"
                        app:layout_constraintWidth_percent="0.75" />

                    <!-- Navigate Button -->
                    <LinearLayout
                        android:id="@+id/btnNavigate1"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_button_dark_blue_12dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/vProgressBase1">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Navigate"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Mark as Complete Button (Full Width) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_btn_complete_provider"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/btnNavigate1">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_check_circle_green"
                            app:tint="#0F766E" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mark as Complete"
                            android:textColor="#0F766E"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        
        <!-- CARD 2: HVAC System Check -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header area with faint background -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F8FAFC"
                    android:paddingTop="20dp"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:id="@+id/tvTitle2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="HVAC System Check"
                        android:textColor="#1E3A8A"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivChat2"
                        android:layout_marginEnd="12dp" />

                    <!-- Status dot & text -->
                    <View
                        android:id="@+id/vStatusDot2"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_teal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle2"
                        app:layout_constraintBottom_toBottomOf="@+id/tvStatus2"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvStatus2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_marginTop="8dp"
                        android:text="IN PROGRESS"
                        android:textColor="#0F766E"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/vStatusDot2"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle2" />

                    <ImageView
                        android:id="@+id/ivChat2"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_messages_active"
                        app:tint="#1E3A8A"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Body Area -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="20dp">

                    <!-- Avatar Profile Block -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/avatar_david"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

                    <TextView
                        android:id="@+id/tvCustomerLabel2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Customer"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        app:layout_constraintStart_toEndOf="@id/ivProfile2"
                        app:layout_constraintTop_toTopOf="@id/ivProfile2"
                        app:layout_constraintBottom_toTopOf="@+id/tvName2"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvName2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Michael Thompson"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivProfile2"
                        app:layout_constraintTop_toBottomOf="@id/tvCustomerLabel2"
                        app:layout_constraintBottom_toBottomOf="@id/ivProfile2" />

                    <!-- Location Block -->
                    <ImageView
                        android:id="@+id/ivLocation2"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/ic_nav_map"
                        app:tint="#0F766E"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivProfile2" />

                    <TextView
                        android:id="@+id/tvLocation2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="20dp"
                        android:text="8832 West River Rd, Penthouse B\nMcLean, VA 22102"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        app:layout_constraintStart_toEndOf="@id/ivLocation2"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivProfile2" />

                    <!-- Elapsed Time Section -->
                    <TextView
                        android:id="@+id/tvElapsedLabel2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="ELAPSED TIME"
                        android:textColor="#475569"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvLocation2" />

                    <TextView
                        android:id="@+id/tvTimer2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="00:24:45"
                        android:textColor="#1E3A8A"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvElapsedLabel2" />

                    <TextView
                        android:id="@+id/tvPercent2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20% Done"
                        android:textColor="#0F766E"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="@id/tvTimer2"
                        android:layout_marginBottom="4dp"/>

                    <!-- Progress Bar -->
                    <View
                        android:id="@+id/vProgressBase2"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_progress_bar_base_bookings"
                        app:layout_constraintTop_toBottomOf="@id/tvTimer2" />

                    <View
                        android:id="@+id/vProgressFill2"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:background="@drawable/bg_progress_bar_provider_fill"
                        app:layout_constraintBottom_toBottomOf="@id/vProgressBase2"
                        app:layout_constraintStart_toStartOf="@id/vProgressBase2"
                        app:layout_constraintTop_toTopOf="@id/vProgressBase2"
                        app:layout_constraintWidth_percent="0.20" />

                    <!-- Navigate Button -->
                    <LinearLayout
                        android:id="@+id/btnNavigate2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_button_dark_blue_12dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/vProgressBase2">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Navigate"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Mark as Complete Button (Full Width) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_btn_complete_provider"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/btnNavigate2">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_check_circle_green"
                            app:tint="#0F766E" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mark as Complete"
                            android:textColor="#0F766E"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
