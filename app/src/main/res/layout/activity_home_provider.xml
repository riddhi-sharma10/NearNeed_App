<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <ImageView
                    android:id="@+id/appLogo"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_logo"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:id="@+id/brandTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="10dp"
                    android:layout_toEndOf="@id/appLogo"
                    android:layout_toStartOf="@id/notificationBell"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/app_name"
                    android:textColor="@color/sapphire_primary"
                    android:textSize="26sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView
                    android:id="@+id/notificationBell"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_bell"
                    app:tint="#64748B"
                    android:contentDescription="@null" />
            </RelativeLayout>

            <!-- GREETING -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/greeting_marcus"
                android:textColor="#1E3A8A"
                android:textSize="32sp"
                android:letterSpacing="-0.01" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/subtext_impact"
                android:textColor="#64748B"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />


            <!-- EARNINGS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/provider_earnings_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="26dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08"
                        android:text="@string/earnings_mtd"
                        android:textColor="#065F46"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/earnings_amount"
                        android:textColor="@color/black"
                        android:textSize="36sp"
                        android:letterSpacing="-0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        app:drawableStartCompat="@drawable/ic_trending_up"
                        android:drawablePadding="6dp"
                        app:drawableTint="#065F46"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/earnings_growth"
                        android:textColor="#065F46"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STATS GRID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/active_jobs_label"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="sans-serif-black"
                            android:text="@string/active_jobs_count"
                            android:textColor="@color/sapphire_primary"
                            android:textSize="24sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/rating_label"
                            android:textColor="@color/text_subheadline"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:fontFamily="sans-serif-black"
                            android:text="@string/rating_value"
                            android:textColor="@color/sapphire_primary"
                            android:textSize="24sp"
                            app:drawableEndCompat="@drawable/ic_star_yellow"
                            android:drawablePadding="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TODAY'S SCHEDULE -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <TextView
                    android:id="@+id/scheduleTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/viewCalendar"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/today_schedule"
                    android:textColor="@color/text_header"
                    android:textSize="19sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/viewCalendar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/view_calendar"
                    android:textColor="@color/sapphire_primary"
                    android:textSize="13sp" />
            </RelativeLayout>

            <!-- SCHEDULE ITEMS REDUCED WRAPPERS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/time_10_00"
                        android:textColor="@color/text_header"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/time_am"
                        android:textColor="@color/provider_schedule_time_text"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginStart="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <View android:id="@+id/borderBlue" android:layout_width="4dp" android:layout_height="50dp" android:layout_centerVertical="true" android:layout_marginStart="2dp" android:background="@drawable/bg_left_border_blue" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="14dp" android:layout_toEndOf="@id/borderBlue" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:text="@string/job_plumbing" android:textColor="@color/text_header" android:textSize="15sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" app:drawableStartCompat="@drawable/ic_loc_pin_small" android:drawablePadding="4dp" app:drawableTint="#64748B" android:fontFamily="sans-serif-medium" android:text="@string/loc_baker_st" android:textColor="#64748B" android:textSize="13sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/time_02_00"
                        android:textColor="@color/text_header"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/time_pm"
                        android:textColor="@color/provider_schedule_time_text"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginStart="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <View android:id="@+id/borderGreen" android:layout_width="4dp" android:layout_height="50dp" android:layout_centerVertical="true" android:layout_marginStart="2dp" android:background="@drawable/bg_dot_green" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="14dp" android:layout_toEndOf="@id/borderGreen" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:text="@string/job_garden" android:textColor="@color/text_header" android:textSize="15sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" app:drawableStartCompat="@drawable/ic_loc_pin_small" android:drawablePadding="4dp" app:drawableTint="#64748B" android:fontFamily="sans-serif-medium" android:text="@string/loc_riverside" android:textColor="#64748B" android:textSize="13sp" />
                        </LinearLayout>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- REQUESTS NEARBY -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <TextView
                    android:id="@+id/requestsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/liveMapBadge"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/requests_nearby"
                    android:textColor="@color/text_header"
                    android:textSize="19sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/liveMapBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_map_badge"
                    android:fontFamily="sans-serif-black"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="@string/live_map"
                    android:textColor="@color/sapphire_primary"
                    android:textSize="11sp" />
            </RelativeLayout>

            <!-- REQUEST CARDS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_toStartOf="@id/thumb1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:text="@string/job_faucet" android:textColor="@color/text_header" android:textSize="17sp" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" app:drawableStartCompat="@drawable/ic_nav_map_final" android:drawablePadding="4dp" app:drawableTint="@color/brand_success" android:fontFamily="sans-serif-black" android:text="@string/distance_0_8" android:textColor="@color/brand_success" android:textSize="13sp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:fontFamily="sans-serif-medium" android:text="@string/price_45_est" android:textColor="#64748B" android:textSize="13sp" />
                            </LinearLayout>
                        </LinearLayout>
                        <com.google.android.material.imageview.ShapeableImageView android:id="@+id/thumb1" android:layout_width="48dp" android:layout_height="48dp" android:layout_alignParentEnd="true" android:src="@drawable/ic_plumber" android:scaleType="centerCrop" app:cornerSize="8dp" app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" android:contentDescription="@null" />
                    </RelativeLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton android:layout_width="0dp" android:layout_height="48dp" android:layout_marginEnd="6dp" android:layout_weight="1" android:text="@string/btn_decline" android:textAllCaps="false" android:textColor="@color/text_header" app:backgroundTint="#F1F5F9" app:cornerRadius="24dp" app:elevation="0dp" />
                        <com.google.android.material.button.MaterialButton android:layout_width="0dp" android:layout_height="48dp" android:layout_marginStart="6dp" android:layout_weight="1" android:text="@string/btn_accept" android:textAllCaps="false" android:textColor="@color/white" app:backgroundTint="@color/sapphire_primary" app:cornerRadius="24dp" app:elevation="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentStart="true" android:layout_toStartOf="@id/thumb2" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:text="@string/job_light" android:textColor="@color/text_header" android:textSize="17sp" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:orientation="horizontal">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" app:drawableStartCompat="@drawable/ic_nav_map_final" android:drawablePadding="4dp" app:drawableTint="@color/brand_success" android:fontFamily="sans-serif-black" android:text="@string/distance_2_4" android:textColor="@color/brand_success" android:textSize="13sp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:fontFamily="sans-serif-medium" android:text="@string/price_80_est" android:textColor="#64748B" android:textSize="13sp" />
                            </LinearLayout>
                        </LinearLayout>
                        <com.google.android.material.imageview.ShapeableImageView android:id="@+id/thumb2" android:layout_width="48dp" android:layout_height="48dp" android:layout_alignParentEnd="true" android:src="@drawable/ic_electrician" android:scaleType="centerCrop" app:cornerSize="8dp" app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" android:contentDescription="@null" />
                    </RelativeLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton android:layout_width="0dp" android:layout_height="48dp" android:layout_marginEnd="6dp" android:layout_weight="1" android:text="@string/btn_decline" android:textAllCaps="false" android:textColor="@color/text_header" app:backgroundTint="#F1F5F9" app:cornerRadius="24dp" app:elevation="0dp" />
                        <com.google.android.material.button.MaterialButton android:layout_width="0dp" android:layout_height="48dp" android:layout_marginStart="6dp" android:layout_weight="1" android:text="@string/btn_accept" android:textAllCaps="false" android:textColor="@color/white" app:backgroundTint="@color/sapphire_primary" app:cornerRadius="24dp" app:elevation="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- VIEW EARNINGS HISTORY -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#F1F5F9"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/ic_wallet" android:layout_width="24dp" android:layout_height="24dp" android:layout_centerVertical="true" android:src="@drawable/ic_payment_wallet_blue" android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="14dp" android:layout_toEndOf="@id/ic_wallet" android:layout_toStartOf="@id/ic_arrow" android:fontFamily="sans-serif-black" android:text="@string/view_earnings_history" android:textColor="@color/sapphire_primary" android:textSize="15sp" android:maxLines="1" android:ellipsize="end" />
                    <ImageView android:id="@+id/ic_arrow" android:layout_width="20dp" android:layout_height="20dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_arrow_forward" app:tint="@color/sapphire_primary" android:contentDescription="@null" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:layout_marginBottom="90dp"
        android:src="@drawable/ic_plus_white"
        app:backgroundTint="@color/brand_success"
        app:fabSize="normal"
        app:tint="@color/white"
        android:contentDescription="@null" />

    <include layout="@layout/layout_floating_navbar_seeker" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
