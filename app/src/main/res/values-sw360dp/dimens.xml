<?xml version="1.0" encoding="utf-8"?>
<!-- Overrides for phones with smallest screen width ≤ 360dp (budget/older phones) -->
<resources>
    <!-- Tighten spacing on small screens -->
    <dimen name="screen_padding">16dp</dimen>
    <dimen name="content_padding">12dp</dimen>
    <dimen name="item_spacing">8dp</dimen>

    <!-- Slightly shorter interactive elements -->
    <dimen name="btn_height_primary">48dp</dimen>
    <dimen name="btn_height_secondary">44dp</dimen>
    <dimen name="toolbar_height">56dp</dimen>
    <dimen name="navbar_height">64dp</dimen>
    <dimen name="navbar_icon_container">44dp</dimen>

    <!-- Smaller text on small screens -->
    <dimen name="text_hero">28sp</dimen>
    <dimen name="text_title">18sp</dimen>
    <dimen name="text_subtitle">16sp</dimen>
</resources>
